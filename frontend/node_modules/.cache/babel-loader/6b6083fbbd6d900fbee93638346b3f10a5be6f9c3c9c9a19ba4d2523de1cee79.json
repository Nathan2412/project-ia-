{"ast":null,"code":"import NotificationSystem from './components/NotificationSystem.vue';\nexport default {\n  name: 'App',\n  components: {\n    NotificationSystem\n  },\n  computed: {\n    isLoggedIn() {\n      return this.$store.state.currentUser !== null;\n    },\n    currentUser() {\n      return this.$store.state.currentUser || {};\n    }\n  },\n  methods: {\n    logout() {\n      this.$store.commit('setCurrentUser', null);\n      this.$router.push('/login');\n      this.$refs.notifications.success('Vous avez été déconnecté avec succès.');\n    },\n    // Méthodes pour les notifications accessibles globalement\n    notify(message, type = 'info', timeout = 5000) {\n      return this.$refs.notifications.addNotification(message, type, timeout);\n    }\n  },\n  // Rendre les méthodes de notification accessibles globalement\n  provide() {\n    return {\n      notify: this.notify\n    };\n  }\n};","map":{"version":3,"names":["NotificationSystem","name","components","computed","isLoggedIn","$store","state","currentUser","methods","logout","commit","$router","push","$refs","notifications","success","notify","message","type","timeout","addNotification","provide"],"sources":["C:\\Users\\berda\\Desktop\\project ia\\frontend\\src\\App.vue"],"sourcesContent":["<template>\r\n  <div id=\"app\">\r\n    <nav class=\"navbar navbar-expand-lg navbar-light bg-white\">\r\n      <div class=\"container\">\r\n        <router-link class=\"navbar-brand\" to=\"/\">FilmRecommender</router-link>\r\n        <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#navbarNav\">\r\n          <span class=\"navbar-toggler-icon\"></span>\r\n        </button>\r\n        <div class=\"collapse navbar-collapse\" id=\"navbarNav\">\r\n          <ul class=\"navbar-nav me-auto\">\r\n            <li class=\"nav-item\">\r\n              <router-link class=\"nav-link\" to=\"/\">Accueil</router-link>\r\n            </li>\r\n            <li class=\"nav-item\" v-if=\"isLoggedIn\">\r\n              <router-link class=\"nav-link\" to=\"/recommendations\">Recommandations</router-link>\r\n            </li>\r\n            <li class=\"nav-item\" v-if=\"isLoggedIn\">\r\n              <router-link class=\"nav-link\" to=\"/profile\">Mon profil</router-link>\r\n            </li>\r\n          </ul>\r\n          <div class=\"d-flex\">\r\n            <div v-if=\"isLoggedIn\" class=\"d-flex align-items-center\">\r\n              <span class=\"me-3\">Bienvenue, {{ currentUser.name }}</span>\r\n              <button @click=\"logout\" class=\"btn btn-outline-danger\">Déconnexion</button>\r\n            </div>\r\n            <router-link v-else to=\"/login\" class=\"btn btn-primary\">Connexion</router-link>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </nav>\r\n    \r\n    <div class=\"app-container\">\r\n      <router-view/>\r\n    </div>\r\n    \r\n    <NotificationSystem ref=\"notifications\" />\r\n    \r\n    <footer class=\"bg-light py-4 mt-5\">\r\n      <div class=\"container text-center\">\r\n        <p>© 2025 FilmRecommender - Système de recommandation de films et séries</p>\r\n      </div>\r\n    </footer>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport NotificationSystem from './components/NotificationSystem.vue';\r\n\r\nexport default {\r\n  name: 'App',\r\n  components: {\r\n    NotificationSystem\r\n  },\r\n  computed: {\r\n    isLoggedIn() {\r\n      return this.$store.state.currentUser !== null;\r\n    },\r\n    currentUser() {\r\n      return this.$store.state.currentUser || {};\r\n    }\r\n  },\r\n  methods: {\r\n    logout() {\r\n      this.$store.commit('setCurrentUser', null);\r\n      this.$router.push('/login');\r\n      this.$refs.notifications.success('Vous avez été déconnecté avec succès.');\r\n    },\r\n    // Méthodes pour les notifications accessibles globalement\r\n    notify(message, type = 'info', timeout = 5000) {\r\n      return this.$refs.notifications.addNotification(message, type, timeout);\r\n    }\r\n  },\r\n  // Rendre les méthodes de notification accessibles globalement\r\n  provide() {\r\n    return {\r\n      notify: this.notify\r\n    };\r\n  }\r\n}\r\n</script>\r\n"],"mappings":"AA8CA,OAAOA,kBAAiB,MAAO,qCAAqC;AAEpE,eAAe;EACbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IACVF;EACF,CAAC;EACDG,QAAQ,EAAE;IACRC,UAAUA,CAAA,EAAG;MACX,OAAO,IAAI,CAACC,MAAM,CAACC,KAAK,CAACC,WAAU,KAAM,IAAI;IAC/C,CAAC;IACDA,WAAWA,CAAA,EAAG;MACZ,OAAO,IAAI,CAACF,MAAM,CAACC,KAAK,CAACC,WAAU,IAAK,CAAC,CAAC;IAC5C;EACF,CAAC;EACDC,OAAO,EAAE;IACPC,MAAMA,CAAA,EAAG;MACP,IAAI,CAACJ,MAAM,CAACK,MAAM,CAAC,gBAAgB,EAAE,IAAI,CAAC;MAC1C,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,QAAQ,CAAC;MAC3B,IAAI,CAACC,KAAK,CAACC,aAAa,CAACC,OAAO,CAAC,uCAAuC,CAAC;IAC3E,CAAC;IACD;IACAC,MAAMA,CAACC,OAAO,EAAEC,IAAG,GAAI,MAAM,EAAEC,OAAM,GAAI,IAAI,EAAE;MAC7C,OAAO,IAAI,CAACN,KAAK,CAACC,aAAa,CAACM,eAAe,CAACH,OAAO,EAAEC,IAAI,EAAEC,OAAO,CAAC;IACzE;EACF,CAAC;EACD;EACAE,OAAOA,CAAA,EAAG;IACR,OAAO;MACLL,MAAM,EAAE,IAAI,CAACA;IACf,CAAC;EACH;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}